curl -X POST "http://localhost:8000/tasks" \
     -H "Content-Type: application/json" \
     -d '{
           "mode": "SYNC",
           "model_id": 1,
           "payload": {
             "input_shape": [1, 10],
             "num_runs": 100,
             "warmup_runs": 10
           },
           "config": {
               "retry": 3,
               "timeout_sec": 10
           }
         }'
